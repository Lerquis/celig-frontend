---
export const prerender = false;
import { podcastApi } from "@/api";
import Container from "../atoms/Container.astro";

let podcasts = [];
const response = await podcastApi.getPodcasts();
if (response.status === 200) podcasts = response.body.podcasts;
---

<Container customClass="content-container-podcasts hidden opacity-0">
  <div
    class="col-start-1 col-span-4 md:col-span-8 xl:col-span-12 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-[10px]"
  >
    {
      podcasts.map((podcast: { url: string }) => (
        <iframe
          class="rounded-[12px]"
          src={podcast.url}
          width="100%"
          height="152"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        />
      ))
    }
  </div>
</Container>
