---
import Container from "../atoms/Container.astro";
import Parragraph from "../atoms/Parragraph.astro";
import SectionTitle from "../atoms/SectionTitle.astro";
import SmallParragraph from "../atoms/SmallParragraph.astro";
import ContactItem from "../molecules/ContactItem.astro";
import { ContactForm } from "./ContactForm.jsx";
---

<footer class="bg-black text-white space-y-[50px] py-[50px]">
  <Container fullWidth={false} customClass="space-y-[-50px] md:space-y-[-80px]">
    <SectionTitle
      title="Estemos en"
      customClass="col-start-1 col-span-4 md:col-span-8"
    />
    <SectionTitle
      title="Contacto"
      serif={true}
      customClass="col-start-2 col-span-3"
    />
  </Container>

  <Container customClass="space-y-[50px]">
    <ContactItem title="Email">
      <a href="mailto:info@celigcr.com"
        ><Parragraph text="info@celigcr.com" customClass="md:text-[20px]" /></a
      >
    </ContactItem>

    <ContactItem title="Numero">
      <Parragraph text="+506 8334 6441" customClass="md:text-[20px]" />
      <Parragraph text="+506 4001 6439" customClass="md:text-[20px]" />
    </ContactItem>

    <ContactItem title="Dirección">
      <Parragraph
        customClass="md:text-[20px]"
        text="Edificio SIGMA segundo Piso San Pedro de Montes de Oca, costado oeste del Mall San Pedro"
      />
    </ContactItem>

    <div
      class="col-start-1 col-span-4 md:col-span-8 border-b-[1px] border-white pb-[50px]"
    >
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4697.576139154609!2d-84.06053812496971!3d9.934085790167998!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa0e352693559b5%3A0xcedd81bd5829edc4!2sCELIG!5e1!3m2!1ses-419!2scr!4v1749342850541!5m2!1ses-419!2scr"
        style="border:0;"
        class="h-[300px] w-full rounded-[10px]"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </Container>

  <Container>
    <ContactForm client:only>
      <button
        type="submit"
        class={`cursor-pointer py-3 px-6 rounded-[4px] border-[1px] border-white hover:bg-black hover:text-white bg-white
         text-black montreg text-[12px] md:text-[16px] float-end w-[150px] transition-all ease-in`}
      >
        Contáctanos
      </button>
    </ContactForm>
  </Container>

  <Container customClass="">
    <div
      class="col-start-1 col-span-4 md:col-span-8 border-t-[1px] border-white pt-[20px] flex justify-between mt-[30px]"
    >
      <SmallParragraph text="© 2025 Celig & LERQ" />
      <SmallParragraph text="Back to top" />
    </div>
  </Container>
</footer>
