---
export const prerender = false;
import { blogApi } from "@/api";
import Container from "../atoms/Container.astro";
import ContenidoEtiquetas from "../molecules/ContenidoEtiquetas.astro";
import BlogItem from "../molecules/BlogItem.astro";
import { SuscribeForm } from "./SuscribeForm";
import ButtonPride from "../atoms/ButtonPride.astro";
import ContentNavBarButton from "../atoms/ContentNavBarButton.astro";

let blogs = [];
const response = await blogApi.getBlogsByTag("");
if (response.status === 200) blogs = response.body.blogs;
---

<Container customClass="content-container-blogs">
  <SuscribeForm client:only>
    <ContentNavBarButton
      tag={true}
      text="Suscribirse"
      customClass="!w-fit h-fit self-end !mx-0"
      type="submit"
    />
  </SuscribeForm>

  <div
    class="col-start-1 col-span-4 md:col-span-8 xl:col-span-12 space-y-[50px]"
  >
    <ContenidoEtiquetas />
    <div class="space-y-[20px] w-full blogs-rewrite">
      {blogs.map((blog: any) => <BlogItem {...blog} />)}
    </div>
  </div>
</Container>

<script>
  import { blogApi } from "@/api";
  import gsap from "gsap";
  import { formatDateToDDMMYYYY } from "@/lib/dateFormatter";

  const tags = document.querySelectorAll(".content-blog-tag");

  const createButtonPride = (
    text: string,
    href: string,
    customClass = "",
    white = false
  ) => {
    const button = document.createElement("button");
    button.className = `${white ? "bg-white text-black" : "bg-black text-white"} 
    font-semibold py-3 px-6 rounded-[4px] relative overflow-hidden cursor-pointer
    ${customClass} buttonAnimation montreg text-[12px] md:text-[16px]`;

    // Crear las franjas de colores
    const colors = [
      "red-500",
      "orange-500",
      "yellow-500",
      "green-500",
      "blue-500",
      "purple-500",
    ];
    colors.forEach((color) => {
      const stripe = document.createElement("div");
      stripe.className = `color-stripe absolute top-0 left-0 w-full h-full bg-${color} opacity-0 transform -translate-x-full`;
      button.appendChild(stripe);
    });

    // Última franja (fondo)
    const lastStripe = document.createElement("div");
    lastStripe.className = `color-stripe absolute top-0 left-0 w-full h-full ${white ? "bg-white" : "bg-black"} opacity-0 transform -translate-x-full`;
    button.appendChild(lastStripe);

    // Contenido del botón
    const span = document.createElement("span");
    span.className = "relative z-[5]";
    const link = document.createElement("a");
    link.href = href;
    link.className = "text-white no-underline";
    link.textContent = text;
    span.appendChild(link);
    button.appendChild(span);

    return button;
  };

  // Función para crear el componente Paragraph
  const createParagraph = (text: string, customClass = "") => {
    const p = document.createElement("p");
    p.className = `${customClass} montreg tracking-[1px] text-[16px] !leading-[25px]`;
    p.textContent = text;
    return p;
  };

  const createBlogItem = (blog: any) => {
    const blogDiv = document.createElement("div");
    blogDiv.className =
      "bg-white px-4 py-2 md:py-6 md:px-6 flex flex-col space-y-[20px] shadow-2xl rounded-sm";

    // Header con título y tags
    const headerDiv = document.createElement("div");
    headerDiv.className = "space-y-[5px]";

    const title = document.createElement("h3");
    title.className =
      "montreg text-[20px] xl:text-[24px] tracking-[1px] !leading-[25px]";
    title.textContent = blog.title;

    const tags = document.createElement("p");
    tags.className = "text-[12px]";
    tags.textContent = blog.tags.join(", ");

    headerDiv.appendChild(title);
    headerDiv.appendChild(tags);

    // Contenido
    const contentParagraph = createParagraph(
      blog.content,
      "truncate-multiline"
    );

    // Footer con fecha y botón
    const footerDiv = document.createElement("div");
    footerDiv.className = "flex justify-between items-end";

    const dateParagraph = createParagraph(
      formatDateToDDMMYYYY(blog.updatedAt, false)
    );
    const button = createButtonPride(
      "Leer más",
      `/blogs/${blog.slug}`,
      "w-fit self-end"
    );

    footerDiv.appendChild(dateParagraph);
    footerDiv.appendChild(button);

    // Ensamblar el blog item
    blogDiv.appendChild(headerDiv);
    blogDiv.appendChild(contentParagraph);
    blogDiv.appendChild(footerDiv);

    return blogDiv;
  };

  const initializePrideButtons = () => {
    // Verificar si GSAP está disponible
    if (typeof gsap === "undefined") {
      console.warn(
        "GSAP no está disponible. Las animaciones de los botones no funcionarán."
      );
      return;
    }

    const prideButtons = document.querySelectorAll(".buttonAnimation");

    const handleEnter = (event: Event) => {
      const buttonHovered = event.target as HTMLElement;
      const colorStripes = [
        ...buttonHovered.querySelectorAll(".color-stripe"),
      ] as HTMLElement[];
      const lastIndex = colorStripes.length - 1;
      const lastElement = colorStripes[lastIndex];
      const others = colorStripes.slice(0, lastIndex);

      gsap.fromTo(
        others,
        { x: "-100%", opacity: 0 },
        {
          x: "0%",
          opacity: 0.5,
          duration: 0.3,
          stagger: 0.1,
        }
      );

      gsap.fromTo(
        lastElement,
        { x: "-100%", opacity: 0 },
        {
          x: "0%",
          opacity: 1,
          duration: 0.3,
          delay: 0.1 * lastIndex,
        }
      );
    };

    prideButtons.forEach((button) => {
      button.addEventListener("mouseenter", handleEnter);
    });
  };

  const handleDocumentRewrite = (blogs: any) => {
    const blogsRewrite = document.querySelector(
      ".blogs-rewrite"
    ) as HTMLElement;
    if (!blogsRewrite) return;

    // Limpiar contenido existente
    blogsRewrite.innerHTML = "";

    // Verificar si hay blogs
    if (!blogs || blogs.length === 0) {
      // Crear mensaje de "no hay blogs"
      const emptyMessage = createParagraph(
        "Aún no existen blogs disponibles. ¡Pronto tendremos contenido nuevo para ti!",
        "text-center text-gray-600 py-8"
      );
      blogsRewrite.appendChild(emptyMessage);
      return;
    }

    // Agregar clase de espaciado
    blogsRewrite.className = "space-y-[20px] w-full blogs-rewrite";

    // Crear y agregar cada blog item
    blogs.forEach((blog: any) => {
      const blogItem = createBlogItem(blog);
      blogsRewrite.appendChild(blogItem);
    });

    // Inicializar animaciones de botones después de crear los elementos
    setTimeout(() => {
      initializePrideButtons();
    }, 100);
  };

  const handleDocumentLoading = (isLoading: boolean) => {
    const blogsRewrite = document.querySelector(".blogs-rewrite");
    if (!blogsRewrite) return;
    blogsRewrite.innerHTML = `
      <div class="loading-container" style="
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 200px;
        padding: 40px;
      ">
        <div class="spinner" style="
          width: 50px;
          height: 50px;
          border: 4px solid #f3f3f3;
          border-top: 4px solid #3498db;
          border-radius: 50%;
          animation: spin 1s linear infinite;
          margin-bottom: 20px;
        "></div>
      </div>
    `;

    if (!document.querySelector("#loading-spinner-styles")) {
      const style = document.createElement("style");
      style.id = "loading-spinner-styles";
      style.textContent = `
        @keyframes spin {
          0% { transform: rotate(0deg); }
          100% { transform: rotate(360deg); }
        }
        
        .loading-container {
          transition: opacity 0.3s ease-in-out;
        }
      `;
      document.head.appendChild(style);
    }
  };

  const handleRequest = async () => {
    // obtenemos todas las tags seleccionadas
    const tagsSelected = document.querySelectorAll(".tag-selected");
    const tags = [...tagsSelected].map((tagItem: any) => tagItem.innerText);

    // llamamos al api
    handleDocumentLoading(true);
    const response = await blogApi.getBlogsByTag(tags as any);
    handleDocumentRewrite(response.status === 200 ? response.body.blogs : []);
  };

  const handleTagClick = async (e: any) => {
    if (!e.target) return;
    // marcamos como seleccionada o no seleccionada
    if (![...e.target.classList].includes("tag-selected"))
      e.target.classList.add("tag-selected");
    else e.target.classList.remove("tag-selected");
    handleRequest();
  };

  tags.forEach((tag) => {
    tag.addEventListener("click", handleTagClick);
  });
</script>
