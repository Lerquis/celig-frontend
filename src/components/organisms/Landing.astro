---
import { MoveDown } from "lucide-react";
import Container from "../atoms/Container.astro";
import CleanLogo from "../atoms/CleanLogo.astro";
import FlagLine from "../atoms/FlagLine.astro";
---

<section class="h-[100dvh] w-screen relative py-4 overflow-hidden">
  <img
    src="/HeroImage2.jpg"
    class="w-full h-full object-cover absolute top-0 z-[-1] brightness-50"
  />
  <Container fullWidth={false} customClass="items-start pb-8 md:h-[80dvh]">
    <div class="flex gap-2 items-center col-start-1 col-span-3">
      <CleanLogo width="w-[75px] md:w-[100px]" />
      <p class="text-[48px] md:text-[96px] text-white font-bold montreg">
        CELIG
      </p>
    </div>
    <div class="md:hidden">
      <FlagLine />
    </div>
  </Container>
  <Container fullWidth={false} customClass="items-center">
    <p class="text-white rosdnl uppercase text-[20px] col-start-1 col-span-3">
      Bufete de abogacia especializado en derechos lgbtiq+
    </p>
    <div class="col-start-4 col-span-4 hidden md:flex">
      <FlagLine />
    </div>
    <MoveDown
      className="mx-auto mt-[-20px] md:mt-0"
      color="white"
      size="32"
      client:visible
    />
  </Container>
</section>
