---
import Container from "../atoms/Container.astro";
import SectionTitle from "../atoms/SectionTitle.astro";
import ServicioItem from "../molecules/ServicioItem.astro";

const services = [
  { label: "Consulta Virtual", href: "/servicio/consulta-virtual" },
  { label: "Consulta Presencial", href: "/servicio/consulta-presencial" },
  { label: "Sucesiones", href: "/servicio/sucesiones" },
  { label: "Defensa de derechos LGBTIQ+", href: "/servicio/derechos-lgbtiq+" },
  {
    label: "Matrimonios entre parejas del mismo sexo",
    href: "/servicio/matrimonios",
  },
  { label: "Servicio Notariales", href: "/servicio/notariales" },
];
---

<section class="mb-[200px] space-y-[100px]" id="servicios">
  <Container
    fullWidth={false}
    customClass="space-y-[-50px] md:space-y-[-80px] title-animation"
  >
    <SectionTitle title="Nuestros" customClass="col-start-1 col-span-4" />
    <SectionTitle
      title="Servicios"
      serif={true}
      customClass="col-start-2 col-span-3"
    />
  </Container>

  <Container customClass="space-y-[20px] items-center">
    {services.map((item) => <ServicioItem {...item} />)}
  </Container>
</section>
