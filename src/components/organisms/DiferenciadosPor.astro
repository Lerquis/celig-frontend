---
import Container from "../atoms/Container.astro";
import SectionTitle from "../atoms/SectionTitle.astro";
import DiferenciadoItem from "../molecules/DiferenciadoItem.astro";

const diffBy = [
  {
    title1Sans: "Cuidar los ",
    title1Serif: "detalles",
    title2Sans: "Cumpliendo con la ",
    title2Serif: "ley",
    parragraph: `Nos encargamos minuciosamente de cada detalle para garantizar una ceremonia legal. 
    No cumplir con este requisito podría tener serias implicaciones legales para todos. Tu boda con nosotros es 
    legalidad y tranquilidad.`,
  },
  {
    title1Sans: "Atención ",
    title1Serif: "personalizada",
    title2Sans: "Celebra el ",
    title2Serif: "amor",
    parragraph: `Cada unión para Celig es única. Con una variedad de paquetes que se adaptan a todos los gustos, 
    hacemos que cada boda sea especial. Además, Celig se traslada a cualquier rincón del país, llevando la 
    celebración donde el amor los lleve.`,
  },
  {
    title1Sans: "Privacidad ",
    title1Serif: "y respeto",
    parragraph: `Queremos que te sientas cómodo en cada momento, manteniendo siempre el respeto y la confidencialidad
     que mereces. Además, brindamos un seguimiento excepcional a nuestros clientes, para tu tranquilidad y satisfacción constante.`,
  },
  {
    title1Sans: "Experiencia ",
    title1Serif: "vivida",
    title2Sans: "Empatía ",
    title2Serif: "genuina",
    parragraph: `Ana Isabel te atiende personalmente en cada consulta y proceso. Como madre de hijos LGBTIQ+, 
    comprende profundamente las necesidades de nuestra comunidad desde la vivencia personal. Esta experiencia, 
    sumada a más de 30 años en derecho, te brinda la confianza de trabajar con alguien que realmente entiende 
    tu realidad y te acompaña con empatía genuina en cada paso.`,
  },
];
---

<section class="mb-[200px] space-y-[100px]">
  <Container
    fullWidth={false}
    customClass="space-y-[-50px] md:space-y-[-80px] title-animation"
  >
    <SectionTitle
      title="Diferenciados"
      customClass="col-start-1 col-span-4 md:col-span-8 text-center xl:col-span-12"
    />
    <SectionTitle
      title="Por"
      serif={true}
      customClass="col-start-1 col-span-4 md:col-span-8 text-center xl:col-span-12"
    />
  </Container>

  <Container fullWidth={false} customClass="space-y-[100px]">
    {diffBy.map((item) => <DiferenciadoItem {...item} />)}
  </Container>
</section>
