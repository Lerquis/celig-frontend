<script>
  // Script para alternar la visibilidad del grid
  document.getElementById("toggleGridBtn")?.addEventListener("click", () => {
    const gridOverlay = document.querySelector(".grid-overlay");
    if (gridOverlay) {
      // Alternar entre mostrar y ocultar
      if (gridOverlay.classList.contains("hidden")) {
        gridOverlay.classList.remove("hidden");
        localStorage.setItem("gridOverlayVisible", "true");
      } else {
        gridOverlay.classList.add("hidden");
        localStorage.setItem("gridOverlayVisible", "false");
      }
    }
  });

  // Restaurar estado al cargar la página
  document.addEventListener("DOMContentLoaded", () => {
    const gridOverlay = document.querySelector(".grid-overlay");
    const isVisible = localStorage.getItem("gridOverlayVisible") === "true";

    if (gridOverlay && isVisible) {
      gridOverlay.classList.remove("hidden");
    }
  });

  // Compatibilidad con Astro View Transitions
  document.addEventListener("astro:after-swap", () => {
    const gridOverlay = document.querySelector(".grid-overlay");
    const isVisible = localStorage.getItem("gridOverlayVisible") === "true";

    if (gridOverlay && isVisible) {
      gridOverlay.classList.remove("hidden");
    }
  });

  function renderGridColumns(count: number) {
    const grid = document.getElementById("gridColumns");
    if (grid) {
      grid.innerHTML = ""; // Limpiar columnas anteriores
      for (let i = 0; i < count; i++) {
        const col = document.createElement("div");
        col.className = "h-full bg-red-500/20";
        grid.appendChild(col);
      }
    }
  }

  function updateGridByScreenSize() {
    const width = window.innerWidth;
    let columns = 4;
    if (width > 767 && width <= 1279) columns = 8;
    if (width >= 1280) {
      columns = 12;
    }
    renderGridColumns(columns);
  }

  window.addEventListener("DOMContentLoaded", updateGridByScreenSize);
  window.addEventListener("resize", () => {
    updateGridByScreenSize();
  });

  // Compatibilidad con Astro View Transitions
  document.addEventListener("astro:after-swap", updateGridByScreenSize);
</script>
