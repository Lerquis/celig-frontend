---
import { formatDateToDDMMYYYY } from "@/lib/dateFormatter";
import Container from "../atoms/Container.astro";
import Parragraph from "../atoms/Parragraph.astro";
import TagBlog from "../atoms/TagBlog.astro";
import TitleServiceBlog from "../atoms/TitleServiceBlog.astro";
import Footer from "@/components/organisms/Footer.astro";

const { blog } = Astro.props;
---

<section class="pt-24 space-y-[50px] xl:space-y-[100px]">
  <Container>
    <TitleServiceBlog text={blog.title} />
    <div
      class={`col-start-1 col-span-4 md:col-span-8 md:w-[50%] md:mx-auto xl:col-span-12 flex flex-wrap 
      justify-center gap-2 mt-[-30px]`}
    >
      {blog.tags.map((tag: string) => <TagBlog {tag} />)}
    </div>
    <div
      class="col-start-1 col-span-4 md:col-span-8 md:w-[50%] md:mx-auto xl:col-span-12 flex justify-between"
    >
      <Parragraph text="Ana Isabel Sibaja" customClass="montbold" />
      <Parragraph text={formatDateToDDMMYYYY(blog.updatedAt, false)} />
    </div>
  </Container>

  <Container>
    {
      blog.content
        .split("\n\n")
        .map((p: string) => (
          <Parragraph
            text={p}
            customClass="col-start-1 col-span-4 md:col-span-8 xl:col-span-12 xl:w-[70%] xl:mx-auto text-justify"
          />
        ))
    }
  </Container>

  <Footer />
</section>
