---
import { formatDateToDDMMYYYY } from "@/lib/dateFormatter";
import ButtonPride from "../atoms/ButtonPride.astro";
import Parragraph from "../atoms/Parragraph.astro";

const { title, tags, updatedAt, content, slug } = Astro.props;
---

<div
  class="bg-white px-4 py-2 md:py-6 md:px-6 flex flex-col space-y-[20px] shadow-2xl rounded-sm"
>
  <div class="space-y-[5px]">
    <h3
      class="montreg text-[20px] xl:text-[24px] tracking-[1px] !leading-[25px]"
    >
      {title}
    </h3>
    <p class="text-[12px]">{tags.join(", ")}</p>
  </div>
  <Parragraph text={content} customClass="truncate-multiline" />
  <div class="flex justify-between items-end">
    <Parragraph text={formatDateToDDMMYYYY(updatedAt, false)} />
    <ButtonPride customClass="w-fit self-end">
      <span class="relative z-[5]">
        <a href={`/blogs/${slug}`} class="text-white no-underline">Leer más</a>
      </span>
    </ButtonPride>
  </div>
</div>
