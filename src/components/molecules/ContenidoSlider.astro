---
const { right, images } = Astro.props;
---

<div
  class={`relative overflow-hidden h-[250px] w-full ${right ? "slider-right" : "slider-left"}`}
>
  <div class={`flex gap-[50px] slider-track slider-track-positioning`}>
    {
      images.map((src: string) => (
        <img
          src={src}
          alt={src}
          class="h-[250px] w-[200px] md:w-[250px] object-cover shrink-0 rounded-lg"
        />
      ))
    }
  </div>
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/all";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const leftSlider: any = document.querySelector(
      ".slider-left .slider-track"
    );
    const rightSlider: any = document.querySelector(
      ".slider-right .slider-track"
    );
    const sliderContainer: any = document.querySelector(".slider-container");

    if (leftSlider && rightSlider && sliderContainer) {
      const createResponsiveAnimations = () => {
        const screenWidth = window.innerWidth;

        // Calcular configuración basada en el ancho de pantalla
        let movementDistance,
          scrubValue,
          initialLeftPosition,
          initialRightPosition;

        if (screenWidth <= 480) {
          // Móviles muy pequeños - posicionamiento inicial diferente
          movementDistance = "35vw";
          scrubValue = 0.8;
          initialLeftPosition = "-40vw"; // Primer slider más a la derecha
          initialRightPosition = "10vw"; // Segundo slider más a la izquierda
        } else if (screenWidth <= 768) {
          // Tablets/móviles grandes - posicionamiento moderado
          movementDistance = "25vw";
          scrubValue = 1.2;
          initialLeftPosition = "-20vw";
          initialRightPosition = "5vw";
        } else if (screenWidth <= 1024) {
          // Tablets grandes/laptops pequeñas - centrado
          movementDistance = "20vw";
          scrubValue = 1.4;
          initialLeftPosition = "0vw";
          initialRightPosition = "0vw";
        } else {
          // Desktop - centrado
          movementDistance = "15vw";
          scrubValue = 1.6;
          initialLeftPosition = "0vw";
          initialRightPosition = "0vw";
        }

        // Limpiar animaciones existentes
        ScrollTrigger.getAll().forEach((trigger) => trigger.kill());

        // Aplicar clases de centrado para dispositivos grandes
        if (screenWidth > 768) {
          leftSlider.style.justifyContent = "flex-start";
          rightSlider.style.justifyContent = "flex-end";
        } else {
          leftSlider.style.justifyContent = "flex-start";
          rightSlider.style.justifyContent = "flex-start";
        }

        // Establecer posicionamiento inicial responsivo
        gsap.set(leftSlider, { x: initialLeftPosition });
        gsap.set(rightSlider, { x: initialRightPosition });

        // Animación para el slider izquierdo (desde posición inicial hacia la derecha)
        gsap.to(leftSlider, {
          x: `${parseFloat(initialLeftPosition) + parseFloat(movementDistance)}vw`,
          scrollTrigger: {
            trigger: sliderContainer,
            start: "top bottom",
            end: "bottom top",
            scrub: scrubValue,
          },
        });

        // Animación para el slider derecho (desde posición inicial hacia la izquierda)
        gsap.to(rightSlider, {
          x: `${parseFloat(initialRightPosition) - parseFloat(movementDistance)}vw`,
          scrollTrigger: {
            trigger: sliderContainer,
            start: "top bottom",
            end: "bottom top",
            scrub: scrubValue,
          },
        });
      };

      // Crear animaciones iniciales
      createResponsiveAnimations();

      // Recrear animaciones en resize
      window.addEventListener("resize", () => {
        createResponsiveAnimations();
      });
    }
  });
</script>
