---
const target = "https://www.celigcr.com/#servicios"; // usa tu dominio CANÓNICO y HTTPS
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Servicios</title>
    <!-- Redirección inmediata (fallback compatible) -->
    <meta http-equiv="refresh" content={`0; url=${target}`} />
  </head>
  <body>
    <!-- <p>Redirigiendo a <a href={target}>Servicios</a>…</p> -->
    <script>
      // Redirección rápida en navegadores modernos
      window.location.replace("https://www.celigcr.com/#servicios");
    </script>
  </body>
</html>
