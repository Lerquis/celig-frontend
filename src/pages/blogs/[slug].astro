---
export const prerender = false;

import { blogApi } from "@/api";
import Background from "@/components/atoms/General/Background.astro";
import GridOverlay from "@/components/atoms/General/GridOverlay.astro";
import BlogsSlugTemplate from "@/components/templates/BlogsSlugTemplate.astro";
import Layout from "@/layouts/Layout.astro";

const { slug } = Astro.params;
const response = await blogApi.getBlogsByTag();
if (response.status !== 200) return Astro.redirect("/404");
const blogInformation = response.body.blogs.find((b: any) => b.slug === slug);
if (!blogInformation) return Astro.redirect("/404");

// Incrementar vistas del blog
try {
  await blogApi.updateView(blogInformation.id);
} catch (error) {
  console.error("Error updating blog views:", error);
}
---

<Layout title={`CELIG - ${blogInformation.title}`}>
  <Background />
  <GridOverlay />

  <BlogsSlugTemplate blog={blogInformation} />
</Layout>
