// const blogInformation = Astro.props as any;

console.log("entra");

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

const blogResponse = await blogApi.getBlogsByTag();
console.log("llama a blogResponse");

const blogInformation = blogResponse.body.blogs.find(
  (b: any) => b.slug === slug
);
if (!blogInformation) return Astro.redirect("/404");
---

<Layout title={`CELIG - ${blogInformation.title}`}>
  <Background />
  <GridOverlay />

  <BlogsSlugTemplate blog={blogInformation} />
</Layout>
